package com.barclays.iportalmonitoring.service.impl;

import com.barclays.iportalmonitoring.model.ConfigMapResponse;
import com.barclays.iportalmonitoring.service.OpenshiftService;
import io.fabric8.kubernetes.api.model.ConfigMap;
import io.fabric8.kubernetes.api.model.ObjectMeta;
import io.fabric8.openshift.client.OpenShiftClient;
import io.fabric8.kubernetes.client.dsl.MixedOperation;
import io.fabric8.kubernetes.client.dsl.Resource;
import io.fabric8.kubernetes.client.dsl.Namespaceable;
import io.fabric8.kubernetes.client.dsl.NonNamespaceOperation;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;

import java.util.*;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

public class ConfigMapServiceImplTest {

    @Mock
    private OpenshiftService openShiftService;

    @Mock
    private OpenShiftClient mockClient;

    @Mock
    private MixedOperation<ConfigMap, ?, Resource<ConfigMap>> mixedOperation;

    @Mock
    private Namespaceable<NonNamespaceOperation<ConfigMap, ?, Resource<ConfigMap>>> namespaceable;

    @Mock
    private NonNamespaceOperation<ConfigMap, ?, Resource<ConfigMap>> nonNamespaceOperation;

    private ConfigMapServiceImpl configMapService;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
        configMapService = new ConfigMapServiceImpl(openShiftService);

        when(openShiftService.getActiveClient()).thenReturn(mockClient);
        when(mockClient.configMaps()).thenReturn((MixedOperation) mixedOperation);
        when(mixedOperation.inNamespace(anyString())).thenReturn((NonNamespaceOperation) nonNamespaceOperation);
    }

    private ConfigMap createConfigMap(String name, Map<String, String> labels) {
        ConfigMap configMap = new ConfigMap();
        ObjectMeta meta = new ObjectMeta();
        meta.setName(name);
        meta.setLabels(labels);
        configMap.setMetadata(meta);
        return configMap;
    }

    @Test
    void testCompareConfigMaps_SameLabels() {
        String project = "test-project";

        ConfigMap glMap = createConfigMap("my-config", Map.of("env", "prod"));
        ConfigMap slMap = createConfigMap("my-config", Map.of("env", "prod"));

        when(nonNamespaceOperation.list().getItems())
                .thenReturn(List.of(glMap))  // GL
                .thenReturn(List.of(slMap)); // SL

        Map<String, ConfigMapResponse> result = configMapService.compareConfigMaps(project);

        assertEquals(1, result.size());
        ConfigMapResponse response = result.get("my-config");
        assertEquals("Available", response.getGl());
        assertEquals("Available", response.getS1());
        assertTrue(((Map<?, ?>) response.getDifference()).get("info").equals("No differences found"));
    }

    @Test
    void testCompareConfigMaps_DifferentLabels() {
        String project = "test-project";

        ConfigMap glMap = createConfigMap("my-config", Map.of("env", "prod"));
        ConfigMap slMap = createConfigMap("my-config", Map.of("env", "dev"));

        when(nonNamespaceOperation.list().getItems())
                .thenReturn(List.of(glMap))  // GL
                .thenReturn(List.of(slMap)); // SL

        Map<String, ConfigMapResponse> result = configMapService.compareConfigMaps(project);

        assertEquals(1, result.size());
        ConfigMapResponse response = result.get("my-config");
        assertEquals("Available", response.getGl());
        assertEquals("Available", response.getS1());

        Map<?, ?> diff = (Map<?, ?>) response.getDifference();
        assertTrue(diff.containsKey("glOnly") || diff.containsKey("s1Only") || diff.containsKey("differences"));
    }

    @Test
    void testCompareConfigMaps_MissingInSL() {
        String project = "test-project";

        ConfigMap glMap = createConfigMap("only-in-gl", Map.of("env", "prod"));

        when(nonNamespaceOperation.list().getItems())
                .thenReturn(List.of(glMap))  // GL
                .thenReturn(Collections.emptyList()); // SL

        Map<String, ConfigMapResponse> result = configMapService.compareConfigMaps(project);

        ConfigMapResponse response = result.get("only-in-gl");
        assertEquals("Available", response.getGl());
        assertEquals("Unavailable", response.getS1());
        assertEquals("ConfigMap Missing in one cluster", ((Map<?, ?>) response.getDifference()).get("info"));
    }

    @Test
    void testCompareConfigMaps_MissingInGL() {
        String project = "test-project";

        ConfigMap slMap = createConfigMap("only-in-sl", Map.of("env", "dev"));

        when(nonNamespaceOperation.list().getItems())
                .thenReturn(Collections.emptyList())  // GL
                .thenReturn(List.of(slMap)); // SL

        Map<String, ConfigMapResponse> result = configMapService.compareConfigMaps(project);

        ConfigMapResponse response = result.get("only-in-sl");
        assertEquals("Unavailable", response.getGl());
        assertEquals("Available", response.getS1());
        assertEquals("ConfigMap Missing in one cluster", ((Map<?, ?>) response.getDifference()).get("info"));
    }
}
```

