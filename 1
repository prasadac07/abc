### 2\. Integration Testing the Controller (`ProjectController`)

This class tests your API endpoints by running a mock version of your application. The service layer is mocked with `@MockBean` to ensure no external calls are made.

**`ProjectControllerTest.java`**

```java
package com.barclays.iportalmonitoring.controller;

import com.barclays.iportalmonitoring.model.EventResponse;
import com.barclays.iportalmonitoring.model.InventoryResponse;
import com.barclays.iportalmonitoring.service.ProjectService;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.reactive.AutoConfigureWebTestClient;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.http.MediaType;
import org.springframework.test.web.reactive.server.WebTestClient;
import reactor.core.publisher.Flux;

import java.util.List;
import java.util.Map;

import static org.mockito.Mockito.when;

@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
@AutoConfigureWebTestClient
class ProjectControllerTest {

    @Autowired
    private WebTestClient webTestClient;

    @MockBean
    private ProjectService mockProjectService;

    @Test
    void getAllProjects_whenClusterIsBoth_returnsListOfStrings() {
        // Arrange
        when(mockProjectService.getAllProjectsBothClusters()).thenReturn(List.of("Project-A", "Project-B"));

        // Act & Assert
        webTestClient.get()
                .uri("/api/iportal/projects?cluster=both")
                .exchange()
                .expectStatus().isOk()
                .expectBodyList(String.class)
                .hasSize(2)
                .contains("Project-A", "Project-B");
    }

    @Test
    void getProjectInventoryByName_shouldReturnInventoryMap() {
        // Arrange
        InventoryResponse glInventory = new InventoryResponse();
        glInventory.setStatus("Active");
        glInventory.setPods(10);
        when(mockProjectService.getProjectInventoryByName("test-project"))
                .thenReturn(Map.of("gl", glInventory));

        // Act & Assert
        webTestClient.get()
                .uri("/api/iportal/projects/inventory/test-project?cluster=both")
                .exchange()
                .expectStatus().isOk()
                .expectBody()
                .jsonPath("$.gl.status").isEqualTo("Active")
                .jsonPath("$.gl.pods").isEqualTo(10);
    }

    @Test
    void getAllProjectEvents_shouldStreamSseEvents() {
        // Arrange
        EventResponse event1 = new EventResponse();
        event1.setReason("Started");
        when(mockProjectService.getProjectEvents("gl", "test-project"))
                .thenReturn(Flux.just(event1));

        // Act & Assert
        webTestClient.get()
                .uri("/api/iportal/projects/events/test-project?cluster=gl")
                .accept(MediaType.TEXT_EVENT_STREAM)
                .exchange()
                .expectStatus().isOk()
                .expectHeader().contentTypeCompatibleWith(MediaType.TEXT_EVENT_STREAM)
                .expectBodyList(EventResponse.class)
                .hasSize(1);
    }
}
