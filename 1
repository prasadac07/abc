package com.barclays.iportalmonitoring.model;

import io.swagger.v3.oas.annotations.media.Schema;
import lombok.Data;

@Data
@Schema(description = "Represents the health status of a single container within a deployment.")
public class HealthCheckResponse {

    @Schema(description = "The name of the deployment.", example = "frontend-v1")
    private String deployment;

    @Schema(description = "The name of a running pod for this deployment.", example = "frontend-v1-abcdef-12345")
    private String podName;

    @Schema(description = "The name of the container.", example = "frontend-container")
    private String container;

    @Schema(description = "The service associated with the deployment.", example = "frontend-svc")
    private String service;

    @Schema(description = "The public URL for the application.", example = "https://shop.example.com")
    private String route;

    @Schema(description = "The path for the liveness probe.", example = "/healthz")
    private String livenessPath;

    @Schema(description = "The live status from the liveness probe.", example = "200 OK")
    private String livenessStatus;

    @Schema(description = "The path for the readiness probe.", example = "/readyz")
    private String readinessPath;

    @Schema(description = "The live status from the readiness probe.", example = "200 OK")
    private String readinessStatus;
}


package com.barclays.iportalmonitoring.controller;

import com.barclays.iportalmonitoring.model.HealthCheckResponse;
import com.barclays.iportalmonitoring.service.HealthCheckService;
import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.Parameter;
import io.swagger.v3.oas.annotations.responses.ApiResponse;
import io.swagger.v3.oas.annotations.responses.ApiResponses;
import io.swagger.v3.oas.annotations.tags.Tag;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.List;

@RestController
@RequestMapping("api/iportal/healthcheck")
@CrossOrigin
@Tag(name = "HealthCheck API", description = "Endpoints for performing live health checks on deployments.")
public class HealthCheckController {

    private final HealthCheckService healthCheckService;

    @Autowired
    public HealthCheckController(HealthCheckService healthCheckService) {
        this.healthCheckService = healthCheckService;
    }

    @Operation(summary = "Perform a health check on all deployments in a project")
    @ApiResponses(value = {
        @ApiResponse(responseCode = "200", description = "Successfully performed the health check."),
        @ApiResponse(responseCode = "404", description = "Project not found.")
    })
    @GetMapping("/{project}")
    public ResponseEntity<List<HealthCheckResponse>> healthCheck(
            @Parameter(description = "The name of the OpenShift project.") @PathVariable String project,
            @Parameter(description = "The target cluster (e.g., 'gl', 'sl').") @RequestParam("cluster") String cluster) {

        List<HealthCheckResponse> result = healthCheckService.checkDeploymentHealth(cluster, project);
        return ResponseEntity.ok(result);
    }
}


package com.barclays.iportalmonitoring.controller;

import com.barclays.iportalmonitoring.service.ResourceQuotaService;
