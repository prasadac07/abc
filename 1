package com.barclays.iportalmonitoring.controller;

import com.barclays.iportalmonitoring.model.PodResponse;
import com.barclays.iportalmonitoring.service.DeploymentService;
import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.Parameter;
import io.swagger.v3.oas.annotations.responses.ApiResponse;
import io.swagger.v3.oas.annotations.responses.ApiResponses;
import io.swagger.v3.oas.annotations.tags.Tag;
import org.springframework.web.bind.annotation.*;

import java.util.List;
import java.util.Map;

@RestController
@RequestMapping("/api/portal/deployments")
@Tag(name = "Deployments API", description = "Endpoints for retrieving information about deployments and pods.")
public class DeploymentController {

    private final DeploymentService deploymentService;

    public DeploymentController(DeploymentService deploymentService) {
        this.deploymentService = deploymentService;
    }

    @Operation(summary = "Get all deployment names in a project")
    @ApiResponses(value = {
        @ApiResponse(responseCode = "200", description = "Successfully retrieved deployment names."),
        @ApiResponse(responseCode = "404", description = "Project not found.")
    })
    @GetMapping("/{project}")
    public List<String> getDeploymentsInProject(
            @Parameter(description = "The name of the OpenShift project.") @PathVariable String project,
            @Parameter(description = "The target cluster (e.g., 'gl', 'sl').") @RequestParam("cluster") String cluster) {
        return deploymentService.getDeploymentsInProject(cluster, project);
    }

    @Operation(summary = "Get pods for a specific deployment")
    @ApiResponses(value = {
        @ApiResponse(responseCode = "200", description = "Successfully retrieved pod information."),
        @ApiResponse(responseCode = "404", description = "Deployment or project not found.")
    })
    @GetMapping("/pods/{deploymentName}/{project}")
    public Map<String, PodResponse> getPodsOfDeployment(
            @Parameter(description = "The name of the deployment.") @PathVariable String deploymentName,
            @Parameter(description = "The name of the OpenShift project.") @PathVariable String project,
            @Parameter(description = "The target cluster (e.g., 'gl', 'sl').") @RequestParam("cluster") String cluster) {
        return deploymentService.getPodsOfDeployment(cluster, project, deploymentName);
    }

    @Operation(
        summary = "Get detailed data for deployments in a project",
        description = "Returns detailed data for all deployments. If cluster='both', returns a map of data for both clusters. Otherwise, returns a list for the specified cluster."
    )
    @ApiResponses(value = {
        @ApiResponse(responseCode = "200", description = "Successfully retrieved deployment data."),
        @ApiResponse(responseCode = "404", description = "Project not found.")
    })
    @GetMapping("/data/{project}")
    public Object getDeploymentsDataInProject(
            @Parameter(description = "The name of the OpenShift project.") @PathVariable String project,
            @Parameter(description = "Specify the cluster ('gl', 'sl') or 'both'.") @RequestParam("cluster") String cluster) {
        if (cluster.equals("both")) {
            return deploymentService.getDeploymentsDataBothClusters(project);
        }
        return deploymentService.getDeploymentsDataInProject(cluster, project);
    }

    @Operation(summary = "Get logs from a specific pod")
    @ApiResponses(value = {
        @ApiResponse(responseCode = "200", description = "Successfully retrieved pod logs."),
        @ApiResponse(responseCode = "404", description = "Pod or project not found.")
    })
    @GetMapping("/pods/logs/{project}/{pod}")
    public List<String> getPodLogs(
            @Parameter(description = "The name of the OpenShift project.") @PathVariable String project,
            @Parameter(description = "The name of the pod.") @PathVariable String pod,
            @Parameter(description = "The target cluster (e.g., 'gl', 'sl').") @RequestParam("cluster") String cluster) {
        return deploymentService.getPodLogs(cluster, project, pod);
    }
}
