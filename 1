package com.barclays.iportalmonitoring.service.impl;

import com.barclays.iportalmonitoring.model.ConfigMapResponse;
import com.barclays.iportalmonitoring.service.ConfigMapService;
import com.barclays.iportalmonitoring.service.OpenshiftService;

import io.fabric8.kubernetes.api.model.ConfigMap;
import io.fabric8.kubernetes.api.model.ObjectMeta;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;

import java.util.*;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.*;

public class ConfigMapServiceImplTest {

    @Mock
    private OpenshiftService openshiftService;

    @Mock
    private ConfigMapService configMapService; // For recursive dependency

    @InjectMocks
    private ConfigMapServiceImpl configMapServiceImpl;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
    }

    private ConfigMap createConfigMap(String name, Map<String, String> labels) {
        ConfigMap configMap = new ConfigMap();
        ObjectMeta meta = new ObjectMeta();
        meta.setName(name);
        meta.setLabels(labels);
        configMap.setMetadata(meta);
        return configMap;
    }

    @Test
    void testCompareConfigMaps_bothClustersHaveSameConfigMapWithSameLabels() {
        String project = "test-project";

        ConfigMap cm1 = createConfigMap("config1", Map.of("key1", "value1"));

        when(configMapService.getConfigMapsFromCluster("gl", project)).thenReturn(List.of(cm1));
        when(configMapService.getConfigMapsFromCluster("sl", project)).thenReturn(List.of(cm1));

        Map<String, ConfigMapResponse> result = configMapServiceImpl.compareConfigMaps(project);

        ConfigMapResponse response = result.get("config1");
        assertEquals("Available", response.getGl());
        assertEquals("Available", response.getS1());
        assertEquals("No differences found", response.getDifference().get("info"));
    }

    @Test
    void testCompareConfigMaps_configMapMissingInOneCluster() {
        String project = "test-project";

        ConfigMap cm1 = createConfigMap("config1", Map.of("key1", "value1"));

        when(configMapService.getConfigMapsFromCluster("gl", project)).thenReturn(List.of(cm1));
        when(configMapService.getConfigMapsFromCluster("sl", project)).thenReturn(List.of());

        Map<String, ConfigMapResponse> result = configMapServiceImpl.compareConfigMaps(project);

        ConfigMapResponse response = result.get("config1");
        assertEquals("Available", response.getGl());
        assertEquals("Unavailable", response.getS1());
        assertEquals("ConfigMap Missing in one cluster", response.getDifference().get("info"));
    }

    @Test
    void testCompareConfigMaps_configMapHasDifferentLabels() {
        String project = "test-project";

        ConfigMap glMap = createConfigMap("config1", Map.of("key1", "value1"));
        ConfigMap slMap = createConfigMap("config1", Map.of("key1", "value2"));

        when(configMapService.getConfigMapsFromCluster("gl", project)).thenReturn(List.of(glMap));
        when(configMapService.getConfigMapsFromCluster("sl", project)).thenReturn(List.of(slMap));

        Map<String, ConfigMapResponse> result = configMapServiceImpl.compareConfigMaps(project);

        ConfigMapResponse response = result.get("config1");
        assertEquals("Available", response.getGl());
        assertEquals("Available", response.getS1());
        assertEquals(false, response.getDifference().isEmpty());
    }
}
