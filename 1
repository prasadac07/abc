package com.barclays.iportalmonitoring.service.impl;

import com.barclays.iportalmonitoring.annotation.ClusterIdentifier;
import com.barclays.iportalmonitoring.annotation.UseOpenShiftClient;
import com.barclays.iportalmonitoring.dto.DeploymentDTO;
import com.barclays.iportalmonitoring.dto.PodContainerDTO;
import com.barclays.iportalmonitoring.dto.PodDTO;
import com.barclays.iportalmonitoring.service.DeploymentService;
import com.barclays.iportalmonitoring.service.OpenShiftService;

import io.fabric8.kubernetes.api.model.*;
import io.fabric8.kubernetes.api.model.apps.Deployment;
import io.fabric8.kubernetes.api.model.apps.DeploymentStrategy;
import io.fabric8.kubernetes.client.KubernetesClient;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.context.annotation.Lazy;
import org.springframework.stereotype.Service;

import java.util.*;
import java.util.stream.Collectors;

@Service
public class DeploymentServiceImpl implements DeploymentService {

    private final OpenShiftService openShiftService;
    private final DeploymentService deploymentService;

    @Autowired
    public DeploymentServiceImpl(OpenShiftService openShiftService, @Lazy DeploymentService deploymentService) {
        this.openShiftService = openShiftService;
        this.deploymentService = deploymentService;
    }

    @Override
    @UseOpenShiftClient
    public List<String> getDeploymentsInProject(@ClusterIdentifier String cluster, String project) {
        return openShiftService.getActiveClient()
                .apps()
                .deployments()
                .inNamespace(project)
                .list()
                .getItems()
                .stream()
                .map(d -> d.getMetadata().getName())
                .collect(Collectors.toList());
    }

    @Override
    @UseOpenShiftClient
    public Map<String, DeploymentDTO> getDeploymentsDataInProject(@ClusterIdentifier String cluster, String project) {
        List<Deployment> deployments = openShiftService.getActiveClient()
                .apps()
                .deployments()
                .inNamespace(project)
                .list()
                .getItems();

        Map<String, DeploymentDTO> response = new HashMap<>();

        for (Deployment deployment : deployments) {
            String name = deployment.getMetadata().getName();
            Map<String, String> labels = deployment.getMetadata().getLabels();
            Container container = deployment.getSpec().getTemplate().getSpec().getContainers().get(0);
            ResourceRequirements resources = container.getResources();

            String cpuLimit = Optional.ofNullable(resources.getLimits())
                    .map(map -> map.get("cpu"))
                    .map(Quantity::toString)
                    .orElse("N/A");

            String cpuRequest = Optional.ofNullable(resources.getRequests())
                    .map(map -> map.get("cpu"))
                    .map(Quantity::toString)
                    .orElse("N/A");

            String memoryLimit = Optional.ofNullable(resources.getLimits())
                    .map(map -> map.get("memory"))
                    .map(Quantity::toString)
                    .orElse("N/A");

            String memoryRequest = Optional.ofNullable(resources.getRequests())
                    .map(map -> map.get("memory"))
                    .map(Quantity::toString)
                    .orElse("N/A");

            Integer ready = Optional.ofNullable(deployment.getStatus().getReadyReplicas()).orElse(0);
            Integer total = Optional.ofNullable(deployment.getStatus().getReplicas()).orElse(0);
            String healthStatus = ready + "/" + total;

            String imageTag = "N/A";
            if (labels != null) {
                imageTag = labels.getOrDefault("destImageTag", "N/A");
            }

            if ("N/A".equals(imageTag)) {
                String image = container.getImage();
                if (image != null && image.contains(":")) {
                    imageTag = image.substring(image.lastIndexOf(":") + 1);
                }
            }

            String branch = labels != null ? labels.getOrDefault("branch", "N/A") : "N/A";
            String strategyType = Optional.ofNullable(deployment.getSpec().getStrategy())
                    .map(DeploymentStrategy::getType)
                    .orElse("N/A");

            DeploymentDTO dto = DeploymentDTO.builder()
                    .name(name)
                    .healthStatus(healthStatus)
                    .cpuLimit(cpuLimit)
                    .cpuRequest(cpuRequest)
                    .memoryLimit(memoryLimit)
                    .memoryRequest(memoryRequest)
                    .branchName(branch)
                    .imageTag(imageTag)
                    .strategyType(strategyType)
                    .labels(labels != null ? labels : Map.of())
                    .build();

            response.put(name, dto);
        }

        return response;
    }

    @Override
    public Map<String, Map<String, DeploymentDTO>> getDeploymentsDataBothClusters(String project) {
        Map<String, DeploymentDTO> glData;
        Map<String, DeploymentDTO> slData;

        try {
            glData = deploymentService.getDeploymentsDataInProject("gl", project);
        } catch (Exception e) {
            glData = Map.of();
        }

        try {
            slData = deploymentService.getDeploymentsDataInProject("sl", project);
        } catch (Exception e) {
            slData = Map.of();
        }

        Set<String> allDeployments = new HashSet<>();
        allDeployments.addAll(glData.keySet());
        allDeployments.addAll(slData.keySet());

        Map<String, Map<String, DeploymentDTO>> result = new HashMap<>();
        for (String dep : allDeployments) {
            Map<String, DeploymentDTO> clusterData = new HashMap<>();
            clusterData.put("gl", glData.getOrDefault(dep, null));
            clusterData.put("sl", slData.getOrDefault(dep, null));
            result.put(dep, clusterData);
        }

        return result;
    }

    @Override
    @UseOpenShiftClient
    public Map<String, PodDTO> getPodsOfDeployment(@ClusterIdentifier String cluster, String project, String deploymentName) {
        KubernetesClient client = openShiftService.getActiveClient();

        Deployment deployment = client.apps().deployments().inNamespace(project).withName(deploymentName).get();
        if (deployment == null) {
            return Map.of("error", PodDTO.builder().podName("Deployment not found").build());
        }

        Map<String, String> selector = deployment.getSpec().getSelector().getMatchLabels();

        List<Pod> pods = client.pods().inNamespace(project).withLabels(selector).list().getItems();

        Map<String, PodDTO> response = new HashMap<>();

        for (Pod pod : pods) {
            PodStatus status = pod.getStatus();

            List<PodContainerDTO> containers = Optional.ofNullable(status.getContainerStatuses())
                    .orElse(List.of())
                    .stream()
                    .map(cs -> {
                        String state = "Unknown";
                        String startedAt = "Unknown";

                        if (cs.getState().getRunning() != null) {
                            state = "Running";
                            startedAt = cs.getState().getRunning().getStartedAt();
                        } else if (cs.getState().getTerminated() != null) {
                            state = "Terminated";
                            startedAt = cs.getState().getTerminated().getReason();
                        } else if (cs.getState().getWaiting() != null) {
                            state = "Waiting";
                            startedAt = cs.getState().getWaiting().getReason();
                        }

                        return PodContainerDTO.builder()
                                .containerId(cs.getContainerID())
                                .isStarted(Boolean.TRUE.equals(cs.getStarted()))
                                .ready(Boolean.TRUE.equals(cs.getReady()))
                                .restartCount(cs.getRestartCount())
                                .startedAt(startedAt)
                                .state(state)
                                .build();
                    })
                    .collect(Collectors.toList());

            PodDTO podDTO = PodDTO.builder()
                    .podName(Optional.ofNullable(pod.getMetadata().getName()).orElse("N/A"))
                    .startTime(Optional.ofNullable(status.getStartTime()).orElse("Unknown"))
                    .podPhase(Optional.ofNullable(status.getPhase()).orElse("Unknown"))
                    .nodeName(Optional.ofNullable(pod.getSpec().getNodeName()).orElse("Unknown"))
                    .podIp(Optional.ofNullable(status.getPodIP()).orElse("Unknown"))
                    .hostIp(Optional.ofNullable(status.getHostIP()).orElse("Unknown"))
                    .containers(containers)
                    .build();

            response.put(pod.getMetadata().getName(), podDTO);
        }

        return response;
    }

    @Override
    @UseOpenShiftClient
    public List<String> getPodLogs(@ClusterIdentifier String cluster, String project, String podName) {
        Pod pod = openShiftService.getActiveClient().pods().inNamespace(project).withName(podName).get();
        if (pod == null) throw new RuntimeException("Unable to find pod with name " + podName);

        List<Container> containers = pod.getSpec().getContainers();
        if (containers == null || containers.isEmpty()) throw new RuntimeException("No containers found in pod " + podName);

        List<String> logs = new ArrayList<>();

        for (Container container : containers) {
            String containerName = container.getName();
            String log = openShiftService.getActiveClient().pods()
                    .inNamespace(project)
                    .withName(podName)
                    .inContainer(containerName)
                    .getLog();

            logs.add("Logs for container: " + containerName + "\n" + log);
        }

        return logs;
    }
}
