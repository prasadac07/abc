// File: src/test/java/com/barclays/iportalmonitoring/controller/ProjectControllerTest.java

package com.barclays.iportalmonitoring.controller;

import com.barclays.iportalmonitoring.model.EventResponse;
import com.barclays.iportalmonitoring.model.InventoryResponse;
import com.barclays.iportalmonitoring.service.ProjectService;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.reactive.WebFluxTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.http.MediaType;
import org.springframework.test.web.reactive.server.WebTestClient;
import reactor.core.publisher.Flux;

import java.util.List;
import java.util.Map;

import static org.mockito.Mockito.when;

@WebFluxTest(ProjectController.class) // Focus on the web layer with the specified controller
class ProjectControllerTest {

    @Autowired
    private WebTestClient webTestClient;

    @MockBean // Creates a Mockito mock and registers it as a bean in the application context
    private ProjectService projectService;

    @Test
    @DisplayName("GET /api/iportal/projects?cluster=gl should return project map")
    void getAllProjects_forSingleCluster_shouldReturnMap() {
        // Given
        Map<String, String> mockProjects = Map.of("proj-1", "Project One", "proj-2", "Project Two");
        when(projectService.getAllProjects("gl")).thenReturn(mockProjects);

        // When & Then
        webTestClient.get()
                .uri("/api/iportal/projects?cluster=gl")
                .accept(MediaType.APPLICATION_JSON)
                .exchange()
                .expectStatus().isOk()
                .expectBody(Map.class)
                .isEqualTo(mockProjects);
    }

    @Test
    @DisplayName("GET /api/iportal/projects?cluster=both should return merged project list")
    void getAllProjects_forBothClusters_shouldReturnList() {
        // Given
        List<String> mockMergedProjects = List.of("proj-1", "proj-2", "proj-3");
        when(projectService.getAllProjectsBothClusters()).thenReturn(mockMergedProjects);

        // When & Then
        webTestClient.get()
                .uri("/api/iportal/projects?cluster=both")
                .accept(MediaType.APPLICATION_JSON)
                .exchange()
                .expectStatus().isOk()
                .expectBody(List.class)
                .isEqualTo(mockMergedProjects);
    }

    @Test
    @DisplayName("GET /api/iportal/projects/inventory/{project} should return inventory map")
    void getProjectInventoryByName_shouldReturnInventoryMap() {
        // Given
        String projectName = "my-test-project";
        InventoryResponse glResponse = new InventoryResponse("Active", 5, 2, 0, 0, 0, 0, 0, 0, 0, 0, 0);
        InventoryResponse s1Response = new InventoryResponse("Active", 10, 4, 0, 0, 0, 0, 0, 0, 0, 0, 0);
        Map<String, InventoryResponse> mockInventory = Map.of("gl", glResponse, "s1", s1Response);

        when(projectService.getProjectInventoryByName(projectName)).thenReturn(mockInventory);

        // When & Then
        webTestClient.get()
                .uri("/api/iportal/projects/inventory/{project}", projectName)
                .accept(MediaType.APPLICATION_JSON)
                .exchange()
                .expectStatus().isOk()
                .expectBody()
                .jsonPath("$.gl.pods").isEqualTo(5)
                .jsonPath("$.s1.pods").isEqualTo(10)
                .jsonPath("$.gl.services").isEqualTo(2)
                .jsonPath("$.s1.services").isEqualTo(4);
    }

    @Test
    @DisplayName("GET /api/iportal/projects/events/{project} should stream SSE events")
    void getAllProjectEvents_shouldStreamSseEvents() {
        // Given
        String projectName = "my-streaming-project";
        String cluster = "s1";
        
        EventResponse event1 = new EventResponse("2025-07-27T00:10:00Z", "Normal", "Scheduled", "Successfully assigned pod to node", "Pod", "my-app-1", projectName);
        EventResponse event2 = new EventResponse("2025-07-27T00:10:05Z", "Normal", "Pulled", "Container image pulled", "Pod", "my-app-1", projectName);
        Flux<EventResponse> eventFlux = Flux.just(event1, event2);

        when(projectService.getProjectEvents(cluster, projectName)).thenReturn(eventFlux);

        // When & Then
        webTestClient.get()
                .uri(uriBuilder -> uriBuilder
                        .path("/api/iportal/projects/events/{project}")
                        .queryParam("cluster", cluster)
                        .build(projectName))
                .accept(MediaType.TEXT_EVENT_STREAM)
                .exchange()
                .expectStatus().isOk()
                .expectHeader().contentTypeCompatibleWith(MediaType.TEXT_EVENT_STREAM)
                .expectBodyList(EventResponse.class) // Consume the stream into a list
                .hasSize(2)
                .contains(event1, event2);
    }
}
