package com.barclays.iportalmonitoring.controller;

import com.barclays.iportalmonitoring.service.RouteService;
import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.Parameter;
import io.swagger.v3.oas.annotations.responses.ApiResponse;
import io.swagger.v3.oas.annotations.responses.ApiResponses;
import io.swagger.v3.oas.annotations.tags.Tag;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/api/iportal/routes")
@Tag(name = "Routes API", description = "Endpoints for retrieving information about routes.")
public class RouteController {

    private final RouteService routeService;

    public RouteController(RouteService routeService) {
        this.routeService = routeService;
    }

    @Operation(
        summary = "Get route details for a project",
        description = "Returns detailed data for all routes. If cluster='both', returns a map of data for both clusters. Otherwise, returns a list for the specified cluster."
    )
    @ApiResponses(value = {
        @ApiResponse(responseCode = "200", description = "Successfully retrieved route details."),
        @ApiResponse(responseCode = "404", description = "Project not found.")
    })
    @GetMapping("/{project}")
    public Object getRoutes(
            @Parameter(description = "The name of the OpenShift project.") @PathVariable String project,
            @Parameter(description = "Specify the cluster ('gl', 'sl') or 'both'.") @RequestParam("cluster") String cluster) {

        if ("both".equalsIgnoreCase(cluster)) {
            return routeService.getRouteDetailsBothClusters(project);
        }
        return routeService.getRouteDetailsFromCluster(cluster, project);
    }
}


