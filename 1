### 1\. Unit Testing the Service (`ProjectServiceImpl`)

This class tests the core logic of your service in complete isolation using **Mockito** to fake the OpenShift connection.

**`ProjectServiceImplTest.java`**

```java
package com.barclays.iportalmonitoring.service.Impl;

import com.barclays.iportalmonitoring.model.EventResponse;
import com.barclays.iportalmonitoring.model.InventoryResponse;
import com.barclays.iportalmonitoring.service.OpenshiftService;
import com.barclays.iportalmonitoring.service.ProjectService;
import io.fabric8.kubernetes.api.model.Event;
import io.fabric8.kubernetes.client.Watcher;
import io.fabric8.openshift.api.model.Project;
import io.fabric8.openshift.client.OpenShiftClient;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Answers;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.mockito.stubbing.Answer;
import reactor.core.publisher.Flux;
import reactor.test.StepVerifier;

import java.util.Collections;
import java.util.Map;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class ProjectServiceImplTest {

    @Mock
    private OpenshiftService openshiftService;

    // Mock the ProjectService interface to handle the self-injection pattern
    @Mock
    private ProjectService selfInjectedProjectService;

    // Use deep stubs for the fluent OpenShift client API
    @Mock(answer = Answers.RETURNS_DEEP_STUBS)
    private OpenShiftClient mockClient;

    @InjectMocks
    private ProjectServiceImpl projectServiceImpl;

    @BeforeEach
    void setUp() {
        // This setup runs before each test
        when(openshiftService.getActiveClient()).thenReturn(mockClient);
    }

    @Test
    void getInventoryForCluster_shouldAggregateResourceCounts() {
        // Arrange
        Project mockProject = mock(Project.class, RETURNS_DEEP_STUBS);
        when(mockClient.projects().withName(anyString()).get()).thenReturn(mockProject);
        when(mockProject.getStatus().getPhase()).thenReturn("Active");
        // Mock resource counts
        when(mockClient.pods().inNamespace(anyString()).list().getItems()).thenReturn(Collections.nCopies(5, null));
        when(mockClient.services().inNamespace(anyString()).list().getItems()).thenReturn(Collections.nCopies(3, null));
        when(mockClient.routes().inNamespace(anyString()).list().getItems()).thenReturn(Collections.nCopies(2, null));
        // Assume other counts are 0
        when(mockClient.apps().deployments().inNamespace(anyString()).list().getItems()).thenReturn(Collections.emptyList());

        // Act
        InventoryResponse response = projectServiceImpl.getInventoryForCluster("gl", "test-project");

        // Assert
        assertNotNull(response);
        assertEquals("Active", response.getStatus());
        assertEquals(5, response.getPods());
        assertEquals(3, response.getServices());
        assertEquals(2, response.getRoutes());
        assertEquals(0, response.getDeployments());
    }

    @Test
    void getProjectEvents_shouldStreamEventsReactively() {
        // Arrange
        Event mockEvent = new Event();
        mockEvent.setReason("Scheduled");
        mockEvent.setMessage("Pod scheduled successfully");
        mockEvent.setLastTimestamp("2025-07-27T00:00:00Z");
        mockEvent.setInvolvedObject(new io.fabric8.kubernetes.api.model.ObjectReference());

        // Use Mockito's Answer to simulate the Watcher callback
        when(mockClient.v1().events().inNamespace(anyString()).watch(any(Watcher.class)))
            .thenAnswer((Answer<Void>) invocation -> {
                Watcher<Event> watcher = invocation.getArgument(0);
                watcher.eventReceived(Watcher.Action.ADDED, mockEvent);
                watcher.onClose(null); // Simulate the watch closing to complete the Flux
                return null;
            });

        // Act
        Flux<EventResponse> eventFlux = projectServiceImpl.getProjectEvents("gl", "test-project");

        // Assert: Use StepVerifier to test the reactive stream
        StepVerifier.create(eventFlux)
                .expectNextMatches(eventResponse -> "Scheduled".equals(eventResponse.getReason()))
                .verifyComplete();
    }
}
