### 2\. `HealthCheckServiceImpl.java` (Implementation)

This is the core logic. It correctly discovers the relationships between `Deployment` -\> `Service` -\> `Route` using labels and selectors.

```java
package com.barclays.iportalmonitoring.service.Impl;

import com.barclays.iportalmonitoring.annotation.ClusterIdentifier;
import com.barclays.iportalmonitoring.annotation.UseOpenShiftClient;
import com.barclays.iportalmonitoring.service.HealthCheckService;
import com.barclays.iportalmonitoring.service.OpenshiftService;
import io.fabric8.kubernetes.api.model.Container;
import io.fabric8.kubernetes.api.model.Probe;
import io.fabric8.kubernetes.api.model.Service;
import io.fabric8.openshift.api.model.Deployment;
import io.fabric8.openshift.api.model.Route;
import io.fabric8.openshift.client.OpenShiftClient;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import java.net.HttpURLConnection;
import java.net.URL;
import java.util.*;
import java.util.stream.Collectors;

@Component // Use @Component or @Service
public class HealthCheckServiceImpl implements HealthCheckService {

    private final OpenshiftService openshiftService;

    @Autowired
    public HealthCheckServiceImpl(OpenshiftService openshiftService) {
        this.openshiftService = openshiftService;
    }

    @Override
    @UseOpenShiftClient
    public List<Map<String, String>> checkDeploymentHealth(@ClusterIdentifier String cluster, String project) {
        OpenShiftClient client = openshiftService.getActiveClient();
        if (client == null) {
            throw new RuntimeException("OpenShift client not available for cluster: " + cluster);
        }

        // 1. Fetch all necessary resources from the cluster upfront for efficiency.
        List<Deployment> deployments = client.apps().deployments().inNamespace(project).list().getItems();
        List<Service> services = client.services().inNamespace(project).list().getItems();
        List<Route> routes = client.routes().inNamespace(project).list().getItems();

        // 2. Create a lookup map from Service Name -> Route URL for fast access.
        Map<String, String> serviceToRouteUrlMap = routes.stream()
                .collect(Collectors.toMap(
                        route -> route.getSpec().getTo().getName(), // Key: the service name
                        route -> { // Value: the full URL
                            String scheme = (route.getSpec().getTls() != null) ? "https" : "http";
                            return scheme + "://" + route.getSpec().getHost();
                        },
                        (url1, url2) -> url1 // If a service is exposed by multiple routes, take the first one.
                ));

        List<Map<String, String>> healthCheckResults = new ArrayList<>();

        // 3. Iterate through each Deployment to find its associated services and routes.
        for (Deployment deployment : deployments) {
            Map<String, String> podLabels = deployment.getSpec().getTemplate().getMetadata().getLabels();
            if (podLabels == null || podLabels.isEmpty()) {
                continue; // Skip deployments that don't define pod labels.
            }

            // 4. Find the Service that selects this Deployment's pods.
            Optional<Service> matchingService = services.stream()
                    .filter(service -> isSelectorMatch(podLabels, service.getSpec().getSelector()))
                    .findFirst();

            // 5. From the service, find the corresponding public Route URL.
            String routeUrl = matchingService
                    .map(service -> serviceToRouteUrlMap.getOrDefault(service.getMetadata().getName(), "N/A"))
                    .orElse("N/A");

            // 6. Process all containers within the deployment to check their health.
            processDeploymentContainers(healthCheckResults, deployment, routeUrl);
        }

        return healthCheckResults;
    }

    /**
     * Helper method to process each container in a deployment, check its probes, and add to the result list.
     */
    private void processDeploymentContainers(List<Map<String, String>> resultList, Deployment deployment, String routeUrl) {
        String deploymentName = deployment.getMetadata().getName();
        for (Container container : deployment.getSpec().getTemplate().getSpec().getContainers()) {
            String containerName = container.getName();

            String livenessPath = getProbePath(container.getLivenessProbe());
            String readinessPath = getProbePath(container.getReadinessProbe());

            String livenessStatus = getHttpStatus(routeUrl, livenessPath);
            String readinessStatus = getHttpStatus(routeUrl, readinessPath);

            Map<String, String> entry = new LinkedHashMap<>();
            entry.put("route", routeUrl);
            entry.put("deployment", deploymentName);
            entry.put("container", containerName);
            entry.put("livenessPath", livenessPath);
            entry.put("livenessStatus", livenessStatus);
            entry.put("readinessPath", readinessPath);
            entry.put("readinessStatus", readinessStatus);
            resultList.add(entry);
        }
    }

    /**
     * Checks if a Service's selector is a subset of a Pod's labels.
     * @return true if all key-value pairs in the serviceSelector are present in the podLabels.
     */
    private boolean isSelectorMatch(Map<String, String> podLabels, Map<String, String> serviceSelector) {
        if (serviceSelector == null || serviceSelector.isEmpty()) {
            return false;
        }
        return podLabels.entrySet().containsAll(serviceSelector.entrySet());
    }

    /**
     * Safely extracts the HTTP GET path from a health probe.
     */
    private String getProbePath(Probe probe) {
        return Optional.ofNullable(probe)
                .map(p -> p.getHttpGet() != null ? p.getHttpGet().getPath() : null)
                .orElse("N/A");
    }

    /**
     * Performs an HTTP GET request to the specified URL and returns the status code and message.
     */
    private String getHttpStatus(String baseUrl, String path) {
        if ("N/A".equals(baseUrl) || "N/A".equals(path)) {
            return "N/A";
        }
        try {
            String fullUrl = baseUrl + (path.startsWith("/") ? path : "/" + path);
            URL url = new URL(fullUrl);
            HttpURLConnection connection = (HttpURLConnection) url.openConnection();
            connection.setConnectTimeout(5000); // 5-second timeout
            connection.setReadTimeout(5000);
            connection.setRequestMethod("GET");
            connection.setInstanceFollowRedirects(true);

            int code = connection.getResponseCode();
            // For successful codes (2xx, 3xx), just return the code and message.
            if (code >= 200 && code < 400) {
                 return code + " " + connection.getResponseMessage();
            }
            // For server/client errors, provide more context.
            return "Error: " + code + " " + connection.getResponseMessage();

        } catch (Exception e) {
            System.err.println("Health check failed for " + baseUrl + path + ": " + e.getClass().getSimpleName() + " - " + e.getMessage());
            return "Unavailable";
        }
    }
}
