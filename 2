```java
package com.barclays.iportalmonitoring.controller;

import com.barclays.iportalmonitoring.service.HealthCheckService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.List;
import java.util.Map;

@RestController
@RequestMapping("api/iportal/healthcheck")
@CrossOrigin // Handles Cross-Origin Resource Sharing
public class HealthCheckController {

    private final HealthCheckService healthCheckService;

    @Autowired
    public HealthCheckController(HealthCheckService healthCheckService) {
        this.healthCheckService = healthCheckService;
    }

    /**
     * Endpoint to trigger a health check for all deployments in a project.
     * Example URL: GET /api/iportal/healthcheck/my-project-name?cluster=gl
     *
     * @param project The name of the project (namespace) from the URL path.
     * @param cluster The target cluster identifier from the request parameter.
     * @return A list of health check statuses for each container in the project.
     */
    @GetMapping("/{project}")
    public ResponseEntity<List<Map<String, String>>> healthCheck(
            @PathVariable String project,
            @RequestParam("cluster") String cluster) {
        
        List<Map<String, String>> result = healthCheckService.checkDeploymentHealth(cluster, project);
        return ResponseEntity.ok(result);
    }
}
